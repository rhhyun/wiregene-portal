# Wiregene Portal runtime
APP_BASE_URL=https://portal.wiregene.com
PUBLIC_PORTAL_HOST=portal.wiregene.com
# warn: log when public host is still Vercel but let Synology update finish.
# synology: fail the scheduler if public host is still Vercel.
PUBLIC_PORTAL_ROUTE_POLICY=warn
WIREGENE_APP_MODE=portal

# Synology Docker package defaults
APP_SOURCE_DIR=/volume1/docker/wiregene-portal
HOST_PORT=3002
CONTAINER_NAME=wiregene-portal

# Access control
APP_BASIC_AUTH_USER=
APP_BASIC_AUTH_PASSWORD=
APP_BASIC_AUTH_USERS=
# Portal administration requires an explicit admin username here. Do not rely
# on APP_BASIC_AUTH_* alone for admin permission.
WIREGENE_ADMIN_EMAILS=
PORTAL_AUTH_CHECK_SECRET=
PORTAL_AUTH_CHECK_URL=https://portal.wiregene.com/api/auth/check

# Portal account storage
REPORT_STORAGE_BACKEND=local-json
REPORT_STORAGE_LOCAL_PATH=.data/portal/research-briefing-storage.json
PORTAL_ACCOUNT_STORAGE_BACKEND=local-json
PORTAL_ACCOUNT_STORAGE_PATH=.data/portal/portal-accounts.json
# Recommended production model:
# - Synology is the primary store: PORTAL_ACCOUNT_STORAGE_BACKEND=local-json
# - Google Drive is the backup mirror: PORTAL_ACCOUNT_GOOGLE_DRIVE_BACKUP=true
PORTAL_ACCOUNT_GOOGLE_DRIVE_BACKUP=false
PORTAL_ACCOUNT_GOOGLE_DRIVE_BACKUP_FILENAME=portal-accounts.synology-backup.json
PORTAL_ACCOUNT_GOOGLE_DRIVE_BACKUP_FILE_ID=
# Google Drive OAuth values are needed only when backup mirroring or a manual
# Google Drive backup command is enabled.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_FOLDER_URL=
GOOGLE_DRIVE_FOLDER_NAME=Research Briefing Platform

# AI, reserved for future portal automation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
